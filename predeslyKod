int funkceRok() {
    int rok;
    int characters;

    do {
        printf("Zadej rok v intervalu %d a %d \n", MIN_YEAR, MAX_YEAR);
        scanf("%d", &rok);

        characters = buffer();
        if (!characters) {
            printf("Invalidni input, zkus to znova. \n");
        } else if (rok > MAX_YEAR || rok < MIN_YEAR) {
            printf("Zadane cislo neni v intervalu od %d do %d. \n", MIN_YEAR, MAX_YEAR);
        }
    } while (rok > MAX_YEAR || rok < MIN_YEAR || !characters);

    return rok;
}

